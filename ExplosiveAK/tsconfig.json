{
  "compilerOptions": {
    "target": "ES2023",
    "module": "commonjs",
    "allowJs": true,
    "declaration": false,
    "outDir": "./out/",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": false,
    "types": []
  },
  "include": ["src"]
}
